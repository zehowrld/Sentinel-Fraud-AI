# 🛡️ SENTINEL FRAUD AI - CONFIGURATION TEMPLATE

# 1. Rename this file to '.env' for local development.

# 2. For Hugging Face/Streamlit, add these to 'Secrets'.

# GOOGLE GEMINI AI (Required)
GOOGLE_KEY=your_gemini_api_key_here

# COINGECKO API (Required)
COINGECKO_KEY=your_coingecko_key_here

# IP QUALITY SCORE (Required)
IP_QUALITY_KEY=your_ip_quality_key_here

# SYSTEM SETTINGS

## ENVIRONMENT=production
LOG_LEVEL=INFO